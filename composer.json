{
  "name": "voku/agent-recall-compiler",
  "description": "Deterministic L2 Meta-Prompt compiler and briefing manager for coding agents.",
  "type": "library",
  "license": "MIT",
  "homepage": "https://github.com/voku/agent-recall-compiler",
  "support": {
    "issues": "https://github.com/voku/agent-recall-compiler/issues",
    "source": "https://github.com/voku/agent-recall-compiler"
  },
  "authors": [
    {
      "name": "Lars Moelleken",
      "homepage": "https://github.com/voku"
    }
  ],
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "voku\\AgentRecallCompiler\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "voku\\AgentRecallCompiler\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/agent-recall-compiler"
  ],
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse --configuration=phpstan.neon.dist",
    "ci": [
      "@composer validate --strict",
      "@test",
      "@phpstan"
    ]
  },
  "config": {
    "allow-plugins": false,
    "sort-packages": true
  }
}
